NORMALLY, ON STEAMOS, IS DEFAULT INSTALLED!

distrobox create --name ubuntu2404 -i ubuntu:24.04
distrobox enter ubuntu2404

sudo apt update
sudo apt install build-essential
sudo apt install libnuma-dev wget gnupg2

sudo usermod -a -G video $LOGNAME

echo 'ADD_EXTRA_GROUPS=1' | sudo tee -a /etc/adduser.conf
echo 'EXTRA_GROUPS=video' | sudo tee -a /etc/adduser.conf
echo 'EXTRA_GROUPS=render' | sudo tee -a /etc/adduser.conf

wget https://repo.radeon.com/amdgpu-install/latest/ubuntu/noble/... open browser and get the link!

sudo apt install ./amdgpu-install TAB
IGNORE ERRORS!
sudo apt update

sudo amdgpu-install --usecase=rocm,hip --no-dkms

export PATH=$PATH:/opt/rocm/bin:/opt/rocm/rocprofiler/bin:/opt/rocm/opencl/bin

exit
podman stop ubuntu2404
distrobox enter ubuntu2404

rocminfo

